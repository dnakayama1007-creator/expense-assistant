# 環境変数サンプル
# このファイルをコピーして .env を作成し、実際の値を入力してください
# cp .env.example .env

# ============================================
# Discord Bot設定（必須）
# Discord Developer Portal > Bot > Token から取得
# https://discord.com/developers/applications
# ============================================
DISCORD_TOKEN=your_discord_bot_token_here

# ============================================
# Cloudflared トンネル設定（任意）
# Cloudflare Zero Trust > Networks > Tunnels から取得
# ============================================
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# ============================================
# ポート設定（任意：デフォルト 3000）
# ============================================
# PORT=3000

# ============================================
# freee API設定（任意）
# WebUIから設定可能（http://localhost:3000 の設定画面）
# freee APIアプリ登録: https://developer.freee.co.jp/
# ============================================
# freeeの設定はWebUIから入力し、freee_config.json（Git除外）に自動保存されます

# ============================================
# Google Cloud Vision API設定（任意）
# OCR（領収書読み取り）に使用
# GCP Console > IAMと管理 > サービスアカウントからJSONキーをダウンロード
# ダウンロードしたJSONを google_service_account.json として配置（Git除外）
# ============================================
